# Copie para `.env` (não versionar) quando for rodar a API localmente.
# SMOKE_* / E2E_* NÃO entram aqui — só no terminal/CI na hora do teste.

# Obrigatórias para a API
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB
JWT_SECRET=troque-por-um-segredo-longo

# Origem do front (Vite em dev)
ALLOWED_ORIGIN=http://localhost:5173

# Opcionais
# PORT=8081
# HOST=0.0.0.0
# APP_URL=http://localhost:5173
# FREE_DAILY_SEARCH_LIMIT=50
# HTTP_SLOW_MS=3000
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_ENABLED=true
# TELEGRAM_WEBHOOK_SECRET=
# (APP_URL público HTTPS é usado no setWebhook do bot)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# ALLOW_REGISTRATIONS=true
# ADMIN_BOOTSTRAP_EMAIL=admin@mediahub.com
# VITE_API_BASE_URL=
